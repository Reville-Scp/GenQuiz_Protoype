<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_background"
    tools:context=".GenquizPageActivity">

    <LinearLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:background="@drawable/mainblue_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/closeBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="GEN QUIZ"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerArea"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surfaceCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:strokeColor="@color/borderSoft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/fileTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="middle"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Selected handout"
                    android:textColor="@color/primaryBlue"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="10"
                    android:progressBackgroundTint="@color/buttonSoft"
                    android:progressTint="@color/primaryBlue" />

                <TextView
                    android:id="@+id/questionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:text="QUESTION 1 OF 20"
                    android:textColor="@color/textMuted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/questionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:lineSpacingExtra="4dp"
                    android:text="1. What is the primary function of a layout resource file in Android development?"
                    android:textColor="@color/textPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/answerA"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/answerDefaultBg"
                    android:gravity="start|center_vertical"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="A. To define the UI structure"
                    android:textAllCaps="false"
                    android:textColor="@color/answerDefaultText"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/borderSoft"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/answerB"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/answerDefaultBg"
                    android:gravity="start|center_vertical"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="B. To handle user interactions"
                    android:textAllCaps="false"
                    android:textColor="@color/answerDefaultText"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/borderSoft"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/answerC"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/answerDefaultBg"
                    android:gravity="start|center_vertical"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="C. To store database records"
                    android:textAllCaps="false"
                    android:textColor="@color/answerDefaultText"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/borderSoft"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/answerD"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/answerDefaultBg"
                    android:gravity="start|center_vertical"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="D. To handle network requests"
                    android:textAllCaps="false"
                    android:textColor="@color/answerDefaultText"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/borderSoft"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/prevBtn"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/buttonSoft"
                        android:text="Previous"
                        android:textAllCaps="false"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/nextBtn"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/primaryBlueDark"
                        android:text="Next"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </ScrollView>

    <FrameLayout
        android:id="@+id/scoreOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:padding="28dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/surfaceCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            app:strokeColor="@color/borderSoft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="28dp">

                <FrameLayout
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:background="@drawable/circle_blue">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF" />

                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="Quiz Complete"
                    android:textColor="@color/textPrimary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/scoreResultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Score: 0/20"
                    android:textColor="@color/primaryBlue"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Tap anywhere to continue"
                    android:textColor="@color/textMuted"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</RelativeLayout>
