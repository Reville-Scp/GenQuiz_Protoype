<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload a PDF, generate 20 questions, answer them, and save your score." />

    <include
        android:id="@+id/topbarnav"
        layout="@layout/topbar_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentTop="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavInclude"
        android:layout_below="@id/topbarnav"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Quiz Generator"
                android:textColor="@color/textPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:text="Upload a PDF, generate 20 questions, then answer and save your score."
                android:textColor="@color/textMuted"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/surfaceCard"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                app:strokeColor="@color/borderSoft"
                app:strokeWidth="1dp"
                android:layout_marginHorizontal="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <FrameLayout
                        android:layout_width="98dp"
                        android:layout_height="96dp"
                        android:background="@drawable/circle_blue">

                        <ImageView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_mainapplogo" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:text="Create a Quiz from Your Handout"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Choose a PDF file from your phone."
                        android:textColor="@color/textMuted"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_marginHorizontal="4dp"
                        android:id="@+id/uploadBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="25dp"
                        android:backgroundTint="@color/primaryBlue"
                        android:text="Upload PDF"
                        android:textAllCaps="false"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        app:cornerRadius="14dp"
                        app:icon="@android:drawable/ic_menu_upload"
                        app:iconGravity="textStart" />

                    <TextView
                        android:id="@+id/fileText"
                        android:layout_width="298dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/input_box"
                        android:ellipsize="middle"
                        android:gravity="center"
                        android:maxLines="1"
                        android:padding="25dp"
                        android:text="No file selected"
                        android:textColor="@color/textSecondary"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_marginHorizontal="4dp"
                        android:id="@+id/generateBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="@color/primaryBlueDark"
                        android:text="Generate Quiz"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        app:cornerRadius="14dp"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart" />

                    <ProgressBar
                        android:id="@+id/generateProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="@color/primaryBlue"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/generateStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Generating quiz, please wait..."
                        android:textColor="@color/textMuted"
                        android:textSize="13sp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <include
        android:id="@+id/bottomNavInclude"
        layout="@layout/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
